{
	"name": "passanger",
	"version": "0.0.1",
	"description": "Offline-first PWA for tracking vehicle fuel consumption, maintenance costs, and driving statistics",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/csabagura/passanger.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:artifacts": "vitest run --config vitest.artifacts.config.ts",
		"test:a11y": "npx playwright test",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^20",
		"@types/papaparse": "^5.5.2",
		"@vite-pwa/sveltekit": "1.1.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.3.0",
		"jsdom": "^28.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"shadcn-svelte": "^1.1.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"workbox-precaching": "^7.4.0",
		"workbox-routing": "^7.4.0"
	},
	"dependencies": {
		"@lucide/svelte": "^0.577.0",
		"clsx": "^2.1.1",
		"dexie": "4.3.0",
		"papaparse": "^5.5.3",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"vite-plugin-pwa": "1.2.0"
	},
	"overrides": {
		"@rollup/plugin-terser": "1.0.0"
	}
}
