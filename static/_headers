/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: frame-ancestors 'none'

# Service worker CSP: controls what the SW execution context can do.
# The document-level CSP (in <meta> tag via kit.csp) does NOT govern workers.
# This header is served by Cloudflare Pages for the SW script response.
# connect-src 'self': SW needs to fetch same-origin assets for precaching.
# script-src 'self': SW may import same-origin scripts.
/service-worker.js
  Content-Security-Policy: default-src 'none'; script-src 'self'; connect-src 'self'
